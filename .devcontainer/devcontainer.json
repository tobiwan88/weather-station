{
  "name": "weather-station (Zephyr)",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "zephyr",

  "workspaceMount": "source=${localWorkspaceFolder},target=/home/zephyr/workspace/weather-station,type=bind,consistency=cached",
  "workspaceFolder": "/home/zephyr/workspace/weather-station",

  // Bind-mount the host's ~/.claude so credentials and global settings survive
  // container restarts without re-authentication.
  // ${localEnv:HOME} resolves to the host user's home directory.
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/zephyr/.claude,type=bind,consistency=cached"
  ],

  // Cleaned up environment: only set what is strictly needed at runtime, avoid pre-setting VIRTUAL_ENV and ZEPHYR_BASE here.
  "remoteEnv": {
    "PATH": "/home/zephyr/.venv/bin:${containerEnv:PATH}"
  },

  // Ensure venv is created and requirements installed on container creation
  // onCreateCommand removed: all setup is handled in Dockerfile

  "postStartCommand": "bash /home/zephyr/workspace/weather-station/.devcontainer/setup-claude.sh; sudo chronyd -q 'pool pool.ntp.org iburst' 2>/dev/null || true; if [ ! -d /home/zephyr/workspace/.west ]; then cd /home/zephyr/workspace/weather-station && west init -l . && west update --narrow; fi",

  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--cap-add=SYS_TIME",
    "--device=/dev/net/tun"
  ],

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "anthropic.claude-vscode",
        "trond-snekvik.devicetree",
        "trond-snekvik.kconfig",
        "marus25.cortex-debug",
        "ms-vscode.cmake-tools"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "/bin/bash",
            "args": ["--init-file", "/home/zephyr/.venv/bin/activate"]
          }
        },
        "C_Cpp.default.compilerPath": "/usr/bin/gcc",
        "C_Cpp.default.intelliSenseMode": "linux-gcc-x64",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "ms-vscode.cpptools",
        "[c]": {
          "editor.defaultFormatter": "ms-vscode.cpptools"
        }
      },
      "tasks": "${localWorkspaceFolder}/.devcontainer/tasks.json",
      "launch": "${localWorkspaceFolder}/.devcontainer/launch.json"
    }
  }
}
