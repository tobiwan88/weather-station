{
  "name": "weather-station (Zephyr)",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": "..",
    "target": "final"
  },
  "remoteUser": "zephyr",

  "workspaceMount": "source=${localWorkspaceFolder},target=/home/zephyr/workspace/weather-station,type=bind,consistency=cached",
  "workspaceFolder": "/home/zephyr/workspace/weather-station",

  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/zephyr/.claude,type=bind,consistency=cached"
  ],

  "remoteEnv": {
    "PATH": "/home/zephyr/.venv/bin:${containerEnv:PATH}",
    "DISPLAY": ":1",
    "LIBGL_ALWAYS_SOFTWARE": "1",
    "SDL_VIDEODRIVER": "x11",
    "SHELL": "/usr/bin/zsh"
  },

  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--cap-add=SYS_TIME",
    "--device=/dev/net/tun",
    "-p", "127.0.0.1:5900:5900"
  ],

  "postStartCommand": "bash /home/zephyr/workspace/weather-station/.devcontainer/start-display.sh; bash /home/zephyr/workspace/weather-station/.devcontainer/setup-claude.sh; sudo chronyd -q 'pool pool.ntp.org iburst' 2>/dev/null || true; if [ ! -d /home/zephyr/workspace/.west ]; then cd /home/zephyr/workspace/weather-station && west init -l . && west update --narrow; fi; west config build.dir-fmt 'build/{board}/{app}' && west packages pip --install && cd /home/zephyr/workspace/weather-station && pre-commit install",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "anthropic.claude-vscode",
        "trond-snekvik.devicetree",
        "trond-snekvik.kconfig",
        "marus25.cortex-debug",
        "ms-vscode.cmake-tools"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "/usr/bin/zsh"
          }
        },
        "C_Cpp.default.compilerPath": "/usr/bin/gcc",
        "C_Cpp.default.intelliSenseMode": "linux-gcc-x64",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "ms-vscode.cpptools"
      }
    }
  }
}
