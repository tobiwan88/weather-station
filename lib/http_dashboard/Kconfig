menuconfig HTTP_DASHBOARD
	bool "HTTP weather dashboard (Chart.js timeseries + config page)"
	depends on HTTP_SERVER
	depends on SENSOR_EVENT
	depends on SENSOR_REGISTRY
	select NET_TCP
	select CONFIG_CMD
	select LOCATION_REGISTRY
	help
	  Serves a browser-accessible dashboard on an HTTP port with two pages:
	    /        — live Chart.js timeseries for temperature and humidity
	    /config  — configuration page (trigger interval, SNTP resync)
	  JSON APIs at /api/data and /api/config support the pages.

if HTTP_DASHBOARD

config HTTP_DASHBOARD_PORT
	int "Listening TCP port"
	default 8080
	depends on HTTP_DASHBOARD

config HTTP_DASHBOARD_HISTORY_SIZE
	int "Samples retained per sensor per type (ring buffer)"
	default 20
	depends on HTTP_DASHBOARD

config HTTP_DASHBOARD_MAX_SENSORS
	int "Max sensor x type slots (uid + type = one slot)"
	default 16
	depends on HTTP_DASHBOARD

config HTTP_DASHBOARD_AUTH
	bool "Enable username/password login and bearer token authentication"
	depends on HTTP_DASHBOARD
	select HTTP_SERVER_CAPTURE_HEADERS
	select SETTINGS
	help
	  Adds a /login page with username+password authentication (default
	  admin:admin) that issues HttpOnly session cookies for browser users.
	  Also keeps a persisted API bearer token for automation clients.
	  Use 'http_dashboard token show' to read the API token.

if HTTP_DASHBOARD_AUTH

config HTTP_DASHBOARD_AUTH_DEFAULT_USER
	string "Default username (written to settings on first boot)"
	default "admin"

config HTTP_DASHBOARD_AUTH_DEFAULT_PASS
	string "Default password (written to settings on first boot)"
	default "admin"

config HTTP_DASHBOARD_SESSION_COUNT
	int "Concurrent browser session slots"
	default 4
	range 1 16

config HTTP_DASHBOARD_AUTH_SHELL
	bool "Shell commands for token/user management"
	depends on SHELL
	default y
	help
	  Adds shell sub-commands:
	    http_dashboard token show   — print current API bearer token
	    http_dashboard token rotate — generate a new API token
	    http_dashboard user show    — print current dashboard username

endif # HTTP_DASHBOARD_AUTH

module = HTTP_DASHBOARD
module-str = HTTP_DASHBOARD
source "subsys/logging/Kconfig.template.log_config"

endif # HTTP_DASHBOARD
