menuconfig SENSOR_REGISTRY
	bool "Sensor registry (uid → metadata)"
	depends on ZBUS
	help
	  Maintains a runtime map from sensor_uid to human-readable metadata
	  (location label, remote flag). Display and MQTT consumers use the
	  registry rather than hardcoding UIDs. Sensor drivers register
	  themselves during SYS_INIT at APPLICATION priority.

if SENSOR_REGISTRY

config SENSOR_REGISTRY_USER_META
	bool "User-settable sensor metadata (description)"
	help
	  Adds runtime-writable description strings, queryable by sensor_uid.
	  Costs SENSOR_REGISTRY_MAX_ENTRIES * (SENSOR_REGISTRY_USER_META_MAX_LEN+1)
	  bytes of BSS when enabled.

config SENSOR_REGISTRY_USER_META_MAX_LEN
	int "Maximum description string length (bytes, excluding NUL)"
	default 32
	range 8 128
	depends on SENSOR_REGISTRY_USER_META

endif # SENSOR_REGISTRY
