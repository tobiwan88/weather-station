menuconfig SNTP_SYNC
	bool "SNTP wall-clock synchronisation"
	depends on NETWORKING
	depends on SNTP
	help
	  Synchronises SYS_CLOCK_REALTIME via sntp_simple() at boot and periodically
	  thereafter. On native_sim use CONFIG_NET_NATIVE_OFFLOADED_SOCKETS so no
	  TAP device is required.

if SNTP_SYNC

config SNTP_SYNC_SERVER
	string "NTP server hostname or IP"
	default "pool.ntp.org"
	help
	  Hostname or IP address of the NTP server to query.

config SNTP_SYNC_TIMEOUT_MS
	int "SNTP query timeout in milliseconds"
	default 5000
	help
	  Maximum time to wait for a response from the NTP server.

config SNTP_SYNC_RESYNC_INTERVAL_S
	int "Periodic resync interval in seconds"
	default 3600
	help
	  How often to re-query the NTP server after the initial sync.
	  Set to 0 to disable periodic resync.

config SNTP_SYNC_THREAD_STACK_SIZE
	int "SNTP sync thread stack size in bytes"
	default 2048
	help
	  Stack size for the dedicated SNTP synchronisation thread. SNTP
	  queries run on this thread rather than the system work queue so that
	  a slow or unreachable server never stalls other work items.

config SNTP_SYNC_THREAD_PRIORITY
	int "SNTP sync thread priority"
	default 10
	help
	  Cooperative or preemptive priority of the SNTP sync thread.
	  In Zephyr, numerically lower values run at higher scheduling priority.
	  Use a numerically higher value than time-critical threads (e.g. sensor
	  triggers) so this thread runs at a lower scheduling priority.

config SNTP_SYNC_PRESYNC_DELAY_MS
	int "Pre-sync settling delay in milliseconds"
	default 0
	help
	  Milliseconds to sleep after waking from the trigger semaphore before
	  opening the SNTP UDP socket.  On platforms with offloaded sockets (e.g.
	  native_sim NSOS) a brief delay lets any in-flight socket operations on
	  other threads drain their epoll state before this thread adds a new fd.
	  Set to 0 to disable (suitable for real hardware where the issue does not
	  apply).

module = SNTP_SYNC
module-str = SNTP_SYNC
source "subsys/logging/Kconfig.template.log_config"

endif # SNTP_SYNC
