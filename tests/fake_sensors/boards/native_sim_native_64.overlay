/*
 * SPDX-License-Identifier: Apache-2.0
 *
 * DT overlay for the fake_sensors test suite.
 * Provides one temperature and one humidity fake sensor so that
 * STRUCT_SECTION_COUNT(fake_sensor_entry) > 0 and the trigger test
 * can receive events on sensor_event_chan.
 */

/ {
	fake_temp_test: fake-temp-test {
		compatible = "fake,temperature";
		sensor-uid = <0x0101>;
		location = "test_bench";
		initial-value-mdegc = <22000>;
		status = "okay";
	};

	fake_hum_test: fake-hum-test {
		compatible = "fake,humidity";
		sensor-uid = <0x0102>;
		location = "test_bench";
		initial-value-mpct = <45000>;
		status = "okay";
	};
};
